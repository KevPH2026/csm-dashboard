# ===========================================
# CSM Dashboard - 环境变量配置
# ===========================================
# 复制此文件为 .env 并填入实际值
# cp .env.example .env

# ---------- 数据库 ----------
# SQLite (本地开发默认)
DATABASE_URL="file:./db/custom.db"

# PostgreSQL (Vercel 生产环境推荐)
# 使用 Vercel Postgres 或其他 PostgreSQL 服务
# DATABASE_URL="postgresql://user:password@host:5432/dbname?schema=public"
# 注意：切换到 PostgreSQL 需要修改 prisma/schema.prisma 中的 provider 为 "postgresql"

# ---------- LLM API ----------
# 方式1: 使用 OpenAI 兼容 API (推荐用于 Vercel)
LLM_API_KEY=""
LLM_BASE_URL=""
LLM_MODEL_NAME=""

# 方式2: 使用 z-ai-web-dev-sdk (仅 z.ai 平台环境可用)
# 无需配置，SDK 自动初始化

# ---------- 可选 ----------
# NextAuth (如需认证功能)
# NEXTAUTH_SECRET=""
# NEXTAUTH_URL=""
